{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "multi-agent-message.schema.json",
  "title": "MultiAgentMessage",
  "type": "object",
  "required": ["version", "header", "payload", "meta"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "header": {
      "type": "object",
      "required": ["message_id", "message_type", "sender_role", "receiver_role", "task_id"],
      "properties": {
        "message_id": {"type": "string"},
        "message_type": {
          "type": "string",
          "enum": ["task_request", "task_result", "audit_review", "conflict_notice", "memory_update"]
        },
        "sender_role": {
          "type": "string",
          "enum": ["planner", "executor", "auditor", "coordinator", "human"]
        },
        "receiver_role": {
          "type": "string",
          "enum": ["planner", "executor", "auditor", "coordinator", "human"]
        },
        "task_id": {"type": "string"}
      }
    },
    "payload": {
      "type": "object"
    },
    "meta": {
      "type": "object",
      "required": ["trace_id", "session_id", "status", "priority"],
      "properties": {
        "trace_id": {"type": "string"},
        "session_id": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed", "needs_human"]
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "conflict_fields": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
