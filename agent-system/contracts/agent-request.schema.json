{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "session_id", "user_input", "allowed_tools"],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "user_input": {
      "type": "string",
      "minLength": 1
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["tool.search", "tool.query_db", "tool.notify"]
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "system": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tenant_id": {"type": "string", "minLength": 1},
            "environment": {"type": "string", "minLength": 1},
            "policy_version": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "approval_token": {"type": "string", "minLength": 1},
        "recipient": {"type": "string", "minLength": 1}
      }
    }
  }
}
