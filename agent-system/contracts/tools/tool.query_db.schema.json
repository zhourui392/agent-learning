{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolQueryDbPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["sql"],
  "properties": {
    "sql": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "runtime_context": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
