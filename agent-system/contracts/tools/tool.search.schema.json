{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolSearchPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "runtime_context": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
