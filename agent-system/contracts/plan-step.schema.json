{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionPlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "session_id", "trace_id", "plan_version", "steps"],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_version": {
      "type": "integer",
      "minimum": 1
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["high_cost", "external_dependency", "uncertain_information"]
      }
    },
    "graph_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_depth", "max_parallel"],
      "properties": {
        "max_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "max_parallel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "goal",
          "tool_id",
          "payload",
          "depends_on",
          "done_criteria"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "tool_id": {
            "type": "string",
            "minLength": 1
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "done_criteria": {
            "type": "string",
            "minLength": 1
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 120
          },
          "allow_rollback": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
